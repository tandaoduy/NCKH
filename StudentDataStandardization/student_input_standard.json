{
  "dataset_name": "student_input_standard_v1",
  "ontology_alignment": {
    "student_id": "StudentID",
    "enrollment_year": "enrollmentYear",
    "current_semester": "currentSemester",
    "chosen_specialization": "hasChosenSpecialization",
    "completed_courses": "hasCompletedCourse",
    "failed_courses": "hasFailedCourse"
  },
  "controlled_values": {
    "specialization_codes": [
      {
        "code": "CNPM",
        "label": "Cong nghe phan mem"
      },
      {
        "code": "HTTT",
        "label": "He thong thong tin"
      },
      {
        "code": "TTMMT",
        "label": "Truyen thong va Mang may tinh"
      }
    ],
    "learning_goals": [
      "dung_han",
      "hoc_vuot",
      "giam_tai"
    ],
    "course_status": [
      "dat",
      "chua_dat"
    ],
    "semester_range": {
      "min": 1,
      "max": 8
    },
    "grade_scale": "0-10"
  },
  "required_fields": [
    "mssv",
    "nam_vao_hoc",
    "chuyen_nganh_chon",
    "danh_sach_mon_da_hoc",
    "diem_tung_mon",
    "trang_thai_dat_chua_dat",
    "so_tin_chi_da_tich_luy",
    "hoc_ky_hien_tai",
    "muc_tieu_hoc_tap"
  ],
  "field_spec": {
    "mssv": {
      "type": "string",
      "description": "Ma sinh vien duy nhat, anh xa voi StudentID."
    },
    "nam_vao_hoc": {
      "type": "integer",
      "description": "Nam bat dau hoc, anh xa voi enrollmentYear."
    },
    "chuyen_nganh_chon": {
      "type": "object",
      "description": "Chuyen nganh sinh vien da chon.",
      "properties": {
        "ma": "string",
        "ten": "string"
      }
    },
    "danh_sach_mon_da_hoc": {
      "type": "array[string]",
      "description": "Danh sach ma mon da tung hoc, gom ca mon dat va chua dat."
    },
    "diem_tung_mon": {
      "type": "object",
      "description": "Map ma mon -> diem he 10."
    },
    "trang_thai_dat_chua_dat": {
      "type": "object",
      "description": "Map ma mon -> dat/chua_dat."
    },
    "so_tin_chi_da_tich_luy": {
      "type": "integer",
      "description": "Tong so tin chi chi tinh cho cac mon dat."
    },
    "hoc_ky_hien_tai": {
      "type": "integer",
      "description": "Hoc ky hien tai theo ontology Semester1..Semester8."
    },
    "muc_tieu_hoc_tap": {
      "type": "string",
      "description": "Muc tieu hoc tap hien tai: dung_han, hoc_vuot, giam_tai."
    }
  },
  "validation_rules": [
    "Tat ca ma mon trong diem_tung_mon phai ton tai trong danh_sach_mon_da_hoc.",
    "Tat ca ma mon trong trang_thai_dat_chua_dat phai ton tai trong danh_sach_mon_da_hoc.",
    "Neu trang_thai_dat_chua_dat[ma_mon] = 'dat' thi ma_mon co the anh xa sang hasCompletedCourse.",
    "Neu trang_thai_dat_chua_dat[ma_mon] = 'chua_dat' thi ma_mon co the anh xa sang hasFailedCourse.",
    "so_tin_chi_da_tich_luy nen bang tong so tin chi cua cac mon co trang thai 'dat'.",
    "hoc_ky_hien_tai nen la so nguyen tu 1 den 8."
  ],
